generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  FINANCIAL_MANAGER
  SALES_MANAGER
  MARKETING
  SUPPORT
  WAREHOUSE
  OPERATOR
}

enum OrderStatus {
  awaiting_confirmation
  confirmed
  processing
  shipped
  delivered
  cancelled
  returned
}

enum PaymentStatus {
  pending
  awaiting_delivery
  paid
  failed
  refunded
  cancelled
}

enum PaymentMethodType {
  cash_on_delivery
  multicaixa_express
  bank_transfer
  credit_card
  paypal
  stripe
}

enum PaymentMethodStatus {
  active
  inactive
  maintenance
  coming_soon
}

enum CouponType {
  percentage
  fixed
}

enum InventoryMovementType {
  in
  out
  adjustment
  reserved
  released
}

enum ImportStatus {
  pending
  in_transit
  customs
  delivered
  cancelled
}

enum CampaignStatus {
  draft
  scheduled
  sent
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum LeadEvent {
  product_viewed
  added_to_cart
  cart_abandoned
  checkout_started
  purchase_completed
}

enum AnalyticsEventType {
  page_view
  product_view
  add_to_cart
  remove_from_cart
  checkout_started
  order_completed
  login
  register
  search
}

enum PointsTransactionType {
  earned_purchase
  earned_referral
  earned_campaign
  earned_signup
  redeemed_discount
  redeemed_coupon
  redeemed_product
  expired
  adjusted
}

enum LoyaltyTier {
  bronze
  silver
  gold
  platinum
}

enum AffiliateStatus {
  active
  inactive
  pending
  suspended
}

enum CommissionType {
  fixed
  percentage
}

enum CommissionStatus {
  pending
  approved
  paid
  cancelled
}

enum WhatsAppProvider {
  twilio
  meta
  ultramsg
  evolution
}

enum WhatsAppMessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum NotificationChannel {
  email
  whatsapp
  push
  in_app
}

enum ProductVisibility {
  visible
  hidden
  maintenance
  out_of_stock
  catalog_only
  members_only
  affiliates_only
  archived
}

enum CustomOrderStatus {
  received
  analyzing
  negotiating
  approved
  rejected
  purchasing
  in_transit
  delivered
  cancelled
}

enum CustomOrderOrigin {
  china
  usa
  portugal
  brazil
  other
}

enum FraudRiskLevel {
  low
  medium
  high
  critical
}

enum PayoutRequestStatus {
  pending
  approved
  paid
  rejected
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String
  role                UserRole  @default(SUPPORT)
  department          String?
  avatar              String?
  active              Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  nif         String?
  password    String?
  avatar      String?
  totalSpent  Decimal  @default(0) @db.Decimal(12, 2)
  ordersCount Int      @default(0)
  active      Boolean  @default(true)
  deletedAt           DateTime?
  suspendedAt         DateTime?
  bannedAt            DateTime?
  loginBlockedUntil   DateTime?
  suspendReason       String?
  banReason           String?
  country             String?
  lastLoginDevice     String?
  referralSource      String?
  riskScore           Int       @default(0)
  fraudScore          Int       @default(0)
  failedLoginAttempts Int       @default(0)
  prefEmails          Boolean   @default(true)
  prefPromos          Boolean   @default(true)
  prefNotifications   Boolean   @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders        Order[]
  payments      Payment[]
  carts         Cart[]
  wishlists      Wishlist[]
  viewHistory    ViewHistory[]
  notifications  Notification[]
  addresses      Address[]
  couponUsages   CouponUsage[]
  leads          Lead[]
  supportTickets SupportTicket[]

  passwordResetTokens PasswordResetToken[]
  pointsTransactions  PointsTransaction[]
  loyaltyAccount      LoyaltyAccount?
  affiliateProfile    Affiliate?
  affiliateReferrals  AffiliateReferral[] @relation("ReferredCustomer")
  analyticsEvents     AnalyticsEvent[]
  pushSubscriptions   PushSubscription[]
  whatsappMessages    WhatsAppMessage[]
  notes            CustomerNote[]
  fraudFlags       FraudFlag[]
  reviews          ProductReview[]
  customOrders     CustomOrder[]

  @@map("customers")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  token      String   @unique
  customerId String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Address {
  id           String   @id @default(cuid())
  customerId   String
  label        String   @default("Casa")
  street       String
  city         String
  province     String
  municipality String?
  district     String?
  reference    String?
  country      String   @default("Angola")
  zipCode      String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?

  // Images (Cloudinary)
  image         String?
  icon          String?
  bannerDesktop String?
  bannerMobile  String?
  ogImage       String?

  // Hierarchy
  parentId String?
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")

  // State & visibility
  active        Boolean @default(true)
  isVisible     Boolean @default(true)
  isFeatured    Boolean @default(false)
  displayOrder  Int     @default(0)
  color         String?

  // Placement flags
  showInHomepage   Boolean @default(false)
  showInMenu       Boolean @default(true)
  showInMobileMenu Boolean @default(true)
  showInFooter     Boolean @default(false)

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  customUrl      String?

  // Audit
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([parentId])
  @@index([slug])
  @@index([isVisible, active, deletedAt])
  @@map("categories")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  brand          String
  categoryId     String
  description    String   @db.Text
  technicalSpecs Json     @default("{}")
  originCountry  String
  images         String[]
  videoUrls      String[]
  warranty       String?
  price          Decimal  @db.Decimal(12, 2)
  salePrice      Decimal? @db.Decimal(12, 2)
  sku            String   @unique
  internalCode   String?
  stock          Int      @default(0)
  minStock       Int      @default(5)
  active         Boolean  @default(true)
  featured       Boolean  @default(false)
  visibility     ProductVisibility @default(visible)
  deletedAt      DateTime?
  isNew          Boolean  @default(false)
  isBestseller   Boolean  @default(false)
  weight         Decimal? @db.Decimal(8, 3)
  dimensions     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category         Category           @relation(fields: [categoryId], references: [id])
  orderItems       OrderItem[]
  cartItems        CartItem[]
  wishlists        Wishlist[]
  reviews          ProductReview[]
  viewHistory      ViewHistory[]
  leads            Lead[]
  inventory        Inventory?
  inventoryMoves   InventoryMovement[]
  analyticsEvents  AnalyticsEvent[]

  @@index([active, categoryId])
  @@index([active, featured])
  @@index([active, createdAt])
  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  customerId      String?
  guestEmail      String?
  guestName       String?
  guestPhone      String?
  status          OrderStatus @default(awaiting_confirmation)
  subtotal        Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  shipping        Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  notes            String?
  shippingAddress  Json
  couponCode       String?
  trackingNumber   String?
  idempotencyKey   String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  customer     Customer?     @relation(fields: [customerId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  couponUsages CouponUsage[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  price           Decimal  @db.Decimal(12, 2)
  salePrice       Decimal? @db.Decimal(12, 2)
  productSnapshot Json

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id                   String            @id @default(cuid())
  orderId              String
  customerId           String?
  paymentMethod        PaymentMethodType
  amount               Decimal           @db.Decimal(12, 2)
  currency             String            @default("AOA")
  transactionReference String?
  paymentStatus        PaymentStatus     @default(pending)
  paymentDate          DateTime?
  gatewayResponse      Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  order    Order     @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@index([paymentStatus])
  @@map("payments")
}

model PaymentMethod {
  id            String              @id @default(cuid())
  name          String
  type          PaymentMethodType   @unique
  status        PaymentMethodStatus @default(active)
  showInStore   Boolean             @default(true)
  sortOrder     Int                 @default(0)
  description   String?
  configuration Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("payment_methods")
}

model Cart {
  id         String   @id @default(cuid())
  customerId String?
  sessionId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer?  @relation(fields: [customerId], references: [id])
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id           String  @id @default(cuid())
  cartId       String
  productId    String
  quantity     Int
  savedForLater Boolean @default(false)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  type      CouponType
  value     Decimal    @db.Decimal(8, 2)
  minOrder  Decimal?   @db.Decimal(12, 2)
  maxUses   Int?
  usedCount Int        @default(0)
  active    Boolean    @default(true)
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String
  orderId    String
  customerId String?
  usedAt     DateTime @default(now())

  coupon   Coupon    @relation(fields: [couponId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("coupon_usages")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  country   String
  contact   String?
  email     String?
  phone     String?
  website   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imports  Import[]
  expenses Expense[]

  @@map("suppliers")
}

model Import {
  id               String       @id @default(cuid())
  supplierId       String
  reference        String       @unique
  products         Json
  totalCost        Decimal      @db.Decimal(12, 2)
  shippingCost     Decimal      @default(0) @db.Decimal(12, 2)
  customsDuty      Decimal      @default(0) @db.Decimal(12, 2)
  otherCosts       Decimal      @default(0) @db.Decimal(12, 2)
  totalLanded      Decimal      @db.Decimal(12, 2)
  status           ImportStatus @default(pending)
  estimatedArrival DateTime?
  actualArrival    DateTime?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("imports")
}

model Inventory {
  id          String   @id @default(cuid())
  productId   String   @unique
  quantity    Int      @default(0)
  reserved    Int      @default(0)
  minStock    Int      @default(5)
  lastUpdated DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@map("inventory")
}

model InventoryMovement {
  id        String                @id @default(cuid())
  productId String
  type      InventoryMovementType
  quantity  Int
  reference String?
  notes     String?
  createdAt DateTime              @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@map("inventory_movements")
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("AOA")
  date        DateTime
  supplierId  String?
  receipt     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@map("expenses")
}

model Lead {
  id         String    @id @default(cuid())
  customerId String?
  sessionId  String?
  productId  String?
  event      LeadEvent
  metadata   Json?
  createdAt  DateTime  @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])

  @@map("leads")
}

model Wishlist {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
  @@map("wishlists")
}

model ViewHistory {
  id         String   @id @default(cuid())
  customerId String?
  sessionId  String?
  productId  String
  viewedAt   DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])

  @@map("view_history")
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("newsletter")
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  subject        String
  body           String         @db.Text
  status         CampaignStatus @default(draft)
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("campaigns")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String?
  customerId String?
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  data       Json?
  createdAt  DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  oldData   Json?
  newData   Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SupportTicket {
  id         String       @id @default(cuid())
  customerId String
  subject    String
  message    String       @db.Text
  status     TicketStatus @default(open)
  adminReply String?      @db.Text
  repliedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

// ─── Analytics ──────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String             @id @default(cuid())
  type       AnalyticsEventType
  customerId String?
  sessionId  String?
  productId  String?
  orderId    String?
  page       String?
  referrer   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime           @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])

  @@index([type, createdAt])
  @@index([customerId])
  @@index([sessionId])
  @@map("analytics_events")
}

// ─── Loyalty / Points ────────────────────────────────────────────────────────

model LoyaltyAccount {
  id            String       @id @default(cuid())
  customerId    String       @unique
  points        Int          @default(0)
  pointsUsed    Int          @default(0)
  pointsExpired Int          @default(0)
  tier          LoyaltyTier  @default(bronze)
  tierUpdatedAt DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  customer     Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions PointsTransaction[]

  @@map("loyalty_accounts")
}

model PointsTransaction {
  id               String                @id @default(cuid())
  customerId       String
  loyaltyAccountId String?
  type             PointsTransactionType
  points           Int
  description      String
  orderId          String?
  expiresAt        DateTime?
  createdAt        DateTime              @default(now())

  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  loyaltyAccount LoyaltyAccount? @relation(fields: [loyaltyAccountId], references: [id])

  @@index([customerId])
  @@map("points_transactions")
}

model LoyaltyConfig {
  id                     String  @id @default(cuid())
  pointsPerKwanza        Decimal @default(1) @db.Decimal(8, 4)
  kwanzaPerPoint         Decimal @default(1) @db.Decimal(8, 4)
  signupBonus            Int     @default(100)
  referralBonus          Int     @default(200)
  referralBonusReferred  Int     @default(100)
  bronzeThreshold        Int     @default(0)
  silverThreshold        Int     @default(500)
  goldThreshold          Int     @default(2000)
  platinumThreshold      Int     @default(10000)
  bronzeDiscount         Decimal @default(0) @db.Decimal(5, 2)
  silverDiscount         Decimal @default(5) @db.Decimal(5, 2)
  goldDiscount           Decimal @default(10) @db.Decimal(5, 2)
  platinumDiscount       Decimal @default(15) @db.Decimal(5, 2)
  pointsExpireDays       Int?
  active                 Boolean @default(true)

  @@map("loyalty_config")
}

// ─── Affiliates ──────────────────────────────────────────────────────────────

model Affiliate {
  id             String          @id @default(cuid())
  customerId     String          @unique
  code           String          @unique
  link           String
  status         AffiliateStatus @default(pending)
  commissionType CommissionType  @default(percentage)
  commissionRate Decimal         @default(5) @db.Decimal(8, 2)
  cookieDays     Int             @default(30)
  totalClicks    Int             @default(0)
  totalSales     Int             @default(0)
  totalEarned    Decimal         @default(0) @db.Decimal(12, 2)
  totalPaid      Decimal         @default(0) @db.Decimal(12, 2)
  paymentDetails Json?
  notes          String?
  balance           Decimal  @default(0) @db.Decimal(12, 2)
  pendingBalance    Decimal  @default(0) @db.Decimal(12, 2)
  qrCode            String?
  landingPageUrl    String?
  suspendedAt       DateTime?
  suspendReason     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  customer    Customer            @relation(fields: [customerId], references: [id])
  referrals   AffiliateReferral[]
  commissions AffiliateCommission[]
  clicks      AffiliateClick[]
  links             AffiliateLink[]
  payoutRequests    AffiliatePayoutRequest[]

  @@map("affiliates")
}

model AffiliateClick {
  id          String   @id @default(cuid())
  affiliateId String
  sessionId   String?
  ip          String?
  userAgent   String?
  referrer    String?
  converted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@map("affiliate_clicks")
}

model AffiliateReferral {
  id          String   @id @default(cuid())
  affiliateId String
  customerId  String
  createdAt   DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])
  customer  Customer  @relation("ReferredCustomer", fields: [customerId], references: [id])

  @@map("affiliate_referrals")
}

model AffiliateCommission {
  id          String           @id @default(cuid())
  affiliateId String
  orderId     String
  amount      Decimal          @db.Decimal(12, 2)
  rate        Decimal          @db.Decimal(8, 2)
  status      CommissionStatus @default(pending)
  paidAt      DateTime?
  createdAt   DateTime         @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@map("affiliate_commissions")
}

// ─── WhatsApp ─────────────────────────────────────────────────────────────────

model WhatsAppConfig {
  id           String           @id @default(cuid())
  provider     WhatsAppProvider @default(evolution)
  apiUrl       String?
  apiKey       String?
  instanceId   String?
  fromNumber   String?
  active       Boolean          @default(false)
  testMode     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("whatsapp_config")
}

model WhatsAppTemplate {
  id        String   @id @default(cuid())
  event     String   @unique
  title     String
  body      String   @db.Text
  active    Boolean  @default(true)
  target    String   @default("customer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("whatsapp_templates")
}

model WhatsAppMessage {
  id          String                @id @default(cuid())
  customerId  String?
  phone       String
  templateId  String?
  body        String                @db.Text
  status      WhatsAppMessageStatus @default(queued)
  provider    WhatsAppProvider      @default(evolution)
  providerRef String?
  error       String?
  sentAt      DateTime?
  createdAt   DateTime              @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

// ─── Push Subscriptions ───────────────────────────────────────────────────────

model PushSubscription {
  id         String   @id @default(cuid())
  customerId String?
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("push_subscriptions")
}

// ─── Platform Settings ────────────────────────────────────────────────────────

model StoreSettings {
  id           String   @id @default(cuid())
  companyName  String   @default("VN Commerce")
  logo         String?
  logoDark     String?
  logoWhite    String?
  favicon      String?
  phone        String?
  whatsapp     String?
