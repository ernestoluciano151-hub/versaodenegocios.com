// ─── Custom Orders ────────────────────────────────────────────────────────────

model CustomOrder {
  id              String            @id @default(cuid())
  customerId      String
  reference       String            @unique
  productName     String
  categoryId      String?
  origin          CustomOrderOrigin @default(other)
  productLink     String?
  quantity        Int               @default(1)
  color           String?
  model           String?
  size            String?
  notes           String?           @db.Text
  images          String[]
  files           String[]
  budget          Decimal?          @db.Decimal(12, 2)
  status          CustomOrderStatus @default(received)
  adminNotes      String?           @db.Text
  quotedPrice     Decimal?          @db.Decimal(12, 2)
  quotedDeadline  String?
  quotedShipping  Decimal?          @db.Decimal(12, 2)
  quotedConditions String?          @db.Text
  supplierId      String?
  convertedProductId String?
  orderId         String?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  customer  Customer               @relation(fields: [customerId], references: [id])
  messages  CustomOrderMessage[]

  @@index([customerId])
  @@index([status])
  @@map("custom_orders")
}

model CustomOrderMessage {
  id            String      @id @default(cuid())
  customOrderId String
  author        String      // 'customer' | 'admin'
  authorName    String?
  text          String      @db.Text
  attachments   String[]
  createdAt     DateTime    @default(now())

  customOrder CustomOrder @relation(fields: [customOrderId], references: [id], onDelete: Cascade)

  @@index([customOrderId])
  @@map("custom_order_messages")
}

// ─── Customer CRM ─────────────────────────────────────────────────────────────

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String?
  authorName String?
  content    String   @db.Text
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_notes")
}

model FraudFlag {
  id         String         @id @default(cuid())
  customerId String
  reason     String
  riskLevel  FraudRiskLevel @default(medium)
  details    Json?
  resolved   Boolean        @default(false)
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("fraud_flags")
}

// ─── Affiliate Pro ────────────────────────────────────────────────────────────

model AffiliateLink {
  id          String   @id @default(cuid())
  affiliateId String
  name        String
  targetType  String   // 'homepage' | 'product' | 'category' | 'campaign' | 'landing'
  targetId    String?
  url         String
  clicks      Int      @default(0)
  conversions Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@map("affiliate_links")
}

model AffiliatePayoutRequest {
  id          String             @id @default(cuid())
  affiliateId String
  amount      Decimal            @db.Decimal(12, 2)
  method      String             // 'bank_transfer' | 'multicaixa'
  details     Json?
  status      PayoutRequestStatus @default(pending)
  processedAt DateTime?
  processedBy String?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
  @@map("affiliate_payout_requests")
}


model HeroBanner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  ctaLabel    String?
  ctaUrl      String?
  ctaLabel2   String?
  ctaUrl2     String?
  imageUrl    String?
  bgColor     String   @default("#111827")
  textColor   String   @default("#ffffff")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hero_banners")
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  customerId String?
  guestName  String?
  rating     Int      // 1-5
  title      String?
  body       String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([productId])
  @@index([customerId])
  @@map("product_reviews")
}
