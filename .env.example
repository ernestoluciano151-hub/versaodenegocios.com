# Base de dados (Supabase ou PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# NextAuth / Auth.js
AUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"   # alias — AUTH_SECRET tem precedência
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Segurança — Password Pepper (OBRIGATÓRIO em produção)
# Gerar com: openssl rand -base64 32
# NUNCA commitar este valor; armazenar apenas em variáveis de ambiente do servidor.
# O Pepper é aplicado via HMAC-SHA256 ANTES do hash Argon2id. Não é guardado na BD.
PASSWORD_PEPPER="gerar-com-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

